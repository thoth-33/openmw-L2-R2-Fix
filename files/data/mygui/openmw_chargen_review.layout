<?xml version="1.0" encoding="UTF-8"?>

<MyGUI type="Layout">
    <Widget type="Window" skin="MW_Dialog" layer="Modal" position="0 0 500 342" align="Center" name="_Main">

        <!-- Player Name, Race, Class and Birthsign -->
        <Widget type="Widget" skin="MW_Box" position="8 8 212 80">
            <Widget type="TextBox" skin="NormalTextController" position="4 4 95 18" name="Name_str">
                <Property key="Caption" value="#{sName}"/>
            </Widget>
            <Widget type="TextBox" skin="SandTextRightController" position="104 4 104 18" name="NameText">
                <Property key="TextAlign" value="Right Top"/>
            </Widget>
            <Widget type="TextBox" skin="NormalTextController" position="4 22 95 18" name="Race_str">
                <Property key="Caption" value="#{sRace}"/>
            </Widget>
            <Widget type="TextBox" skin="SandTextRightController" position="104 22 104 18" name="RaceText">
                <Property key="TextAlign" value="Right Top"/>
            </Widget>
            <Widget type="TextBox" skin="NormalTextController" position="4 42 95 18" name="Class_str">
                <Property key="Caption" value="#{sClass}"/>
            </Widget>
            <Widget type="TextBox" skin="SandTextRightController" position="104 42 104 18" name="ClassText">
                <Property key="TextAlign" value="Right Top"/>
            </Widget>
            <Widget type="TextBox" skin="NormalTextController" position="4 60 95 18" name="Sign_str">
                <Property key="Caption" value="#{sBirthSign}"/>
            </Widget>
            <Widget type="TextBox" skin="SandTextRightController" position="104 60 104 18" name="SignText">
                <Property key="TextAlign" value="Right Top"/>
            </Widget>
        </Widget>

        <!-- Player Health, Magicka and Fatigue -->
        <Widget type="Widget" skin="MW_Box" position="8 96 212 62">
            <Widget type="MWDynamicStat" skin="MW_DynamicStat_Red" position="4 4 204 18" name="Health">
                <UserString key="ToolTipType" value="Layout"/>
                <UserString key="ToolTipLayout" value="HealthToolTip"/>
                <UserString key="ImageTexture_HealthImage" value="icons\k\health.dds"/>
                <Property key="Caption" value="#{sHealth}"/>
            </Widget>
            <Widget type="MWDynamicStat" skin="MW_DynamicStat_Blue" position="4 22 204 18" name="Magicka">
                <UserString key="ToolTipType" value="Layout"/>
                <UserString key="ToolTipLayout" value="HealthToolTip"/>
                <UserString key="ImageTexture_HealthImage" value="icons\k\magicka.dds"/>
                <Property key="Caption" value="#{sMagic}"/>
            </Widget>
            <Widget type="MWDynamicStat" skin="MW_DynamicStat_Green" position="4 40 204 18" name="Fatigue">
                <UserString key="ToolTipType" value="Layout"/>
                <UserString key="ToolTipLayout" value="HealthToolTip"/>
                <UserString key="ImageTexture_HealthImage" value="icons\k\fatigue.dds"/>
                <Property key="Caption" value="#{sFatigue}"/>
            </Widget>
        </Widget>

        <!-- Player attributes -->
        <Widget type="Widget" skin="MW_Box" position="8 166 212 160" name="Attributes" />

        <!-- Player Skills -->
        <Widget type="Widget" skin="MW_Box" position="228 8 263 318" align="Left VStretch" name="Skills">
            <Widget type="ScrollView" skin="MW_ScrollView" position="4 2 261 310" align="Stretch" name="SkillView"/>
        </Widget>
    </Widget>
</MyGUI>
