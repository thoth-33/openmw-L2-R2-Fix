<?xml version="1.0" encoding="UTF-8"?>
<MyGUI type="Layout">
    <Widget type="VBox" skin="MW_DialogNoTransp" layer="SaveLoad" position="0 0 600 360" align="Center" name="_Main">
        <Property key="Padding" value="8"/>
        <Property key="Spacing" value="8"/>
        <Widget type="ComboBox" skin="MW_ComboBox" position="0 0 0 24" name="SelectCharacter">
            <Property key="Caption" value="#{OMWEngine:SelectCharacter}"/>
            <UserString key="HStretch" value="true"/>
        </Widget>
        <Widget type="HBox" skin="">
            <UserString key="HStretch" value="true"/>
            <UserString key="VStretch" value="true"/>
            <Property key="Spacing" value="8"/>
            <Widget type="VBox" skin="">
                <UserString key="HStretch" value="true"/>
                <UserString key="VStretch" value="true"/>
                <Property key="Spacing" value="4"/>
                <Widget type="ListBox" skin="MW_List" position="0 0 200 200" name="SaveList">
                    <UserString key="HStretch" value="true"/>
                    <UserString key="VStretch" value="true"/>
                </Widget>
                <Widget type="Widget" skin="" position="0 0 200 24">
                    <UserString key="HStretch" value="true"/>
                    <UserString key="VStretch" value="false"/>
                    <Widget type="EditBox" skin="MW_TextEdit" position="0 0 305 24" name="SaveNameEdit">
                        <UserString key="HStretch" value="true"/>
                        <UserString key="VStretch" value="false"/>
                    </Widget>
                    <Widget type="Button" skin="MW_Button" position="0 0 305 24" name="DeleteButton">
                        <Property key="Caption" value="#{OMWEngine:DeleteGame}"/>
                        <UserString key="HStretch" value="true"/>
                        <UserString key="VStretch" value="false"/>
                    </Widget>
                    <Widget type="Button" skin="MW_Button" position="0 0 0 0" name="OkButton">
                        <Property key="Visible" value="false"/>
                        <Property key="Caption" value="#{Interface:OK}"/>
                    </Widget>
                    <Widget type="Button" skin="MW_Button" position="0 0 0 0" name="CancelButton">
                        <Property key="Visible" value="false"/>
                        <Property key="Caption" value="#{Interface:Cancel}"/>
                    </Widget>
                </Widget>
            </Widget>
            <Widget type="VBox" skin="">
                <UserString key="HStretch" value="false"/>
                <UserString key="VStretch" value="true"/>
                <Property key="Spacing" value="2"/>
                <Property key="Padding" value="0 0 0 0"/>
                <Widget type="Widget" skin="MW_Box" position="0 0 263 137">
                    <Widget type="ImageBox" skin="ImageBox" position="2 2 259 133" name="Screenshot"/>
                </Widget>
                <Widget type="VBox" skin="">
                    <UserString key="HStretch" value="true"/>
                    <UserString key="VStretch" value="false"/>
                    <Property key="Spacing" value="2"/>
                    <Property key="Padding" value="0 0 0 0"/>
                    <Widget type="AutoSizedEditBox" skin="NormalText" position="0 0 263 0" name="CellName">
                        <Property key="Static" value="true"/>
                        <Property key="MultiLine" value="true"/>
                        <Property key="WordWrap" value="true"/>
                        <Property key="NeedKey" value="false"/>
                        <Property key="TextAlign" value="Left"/>
                        <Property key="Padding" value="0 0 0 0"/>
                    </Widget>
                    <Widget type="AutoSizedEditBox" skin="SandText" position="0 0 263 0" name="InfoText">
                        <Property key="Static" value="true"/>
                        <Property key="MultiLine" value="true"/>
                        <Property key="WordWrap" value="true"/>
                        <Property key="NeedKey" value="false"/>
                        <Property key="Padding" value="0 0 0 0"/>
                    </Widget>
                </Widget>
            </Widget>
        </Widget>
    </Widget>
</MyGUI>
