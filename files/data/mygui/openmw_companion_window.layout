<?xml version="1.0" encoding="UTF-8"?>

<MyGUI type="Layout">
    <Widget type="Window" skin="MW_Window_Pinnable_DialogNoTransp" layer="Windows" position="0 0 600 300" name="_Main">
        <Property key="MinSize" value="245 145"/>

        <!-- Top row with encumbrance bar -->
        <Widget type="HBox" position="8 8 590 24" align="Left Top HStretch" name="_TopRow">
            <Property key="Spacing" value="10"/>

            <Widget type="MWDynamicStat" skin="MW_ChargeBar_Blue" position="0 0 490 24" name="EncumbranceBar" align="Left Top">
            </Widget>
            <Widget type="AutoSizedTextBox" skin="SandText" name="ProfitLabel" align="Left VCenter">
                <Property key="TextAlign" value="Center VCenter"/>
            </Widget>
        </Widget>
        
        <!-- Items -->
        <Widget type="ItemView" skin="MW_ItemView" position="8 38 576 246" name="ItemView" align="Left Top Stretch">
        </Widget>

        <Widget type="HBox" position="5 235 575 24" align="Bottom HStretch">
            <Widget type="Spacer"/>
            <Widget type="AutoSizedButton" skin="MW_Button" name="CloseButton">
                <Property key="Caption" value="#{Interface:Close}"/>
                <Property key="Visible" value="false"/>
                <Property key="Enabled" value="false"/>
            </Widget>
        </Widget>

    </Widget>
</MyGUI>
