<?xml version="1.0" encoding="UTF-8"?>

<MyGUI type="Layout">
    <Widget type="Window" skin="MW_Window_Pinnable_DialogNoTransp" layer="Windows" position="0 0 500 342" name="_Main">
        <Property key="MinSize" value="244 114"/>
        <Widget type="Widget" skin="" name="LeftPane" position="0 0 220 342" align="Stretch">
            <UserString key="LeftOffsetWidth" value="24"/>
            <UserString key="LeftPaneRatio" value="0.44"/>

            <!-- Player health stats -->
            <Widget type="Widget" skin="MW_Box" position="8 8 212 62" align="Left Top HStretch">
                <!-- Health -->
                <Widget type="Widget" skin="" position="4 4 204 18" name="Health" align="Left Top HStretch">
                    <Property key="NeedMouse" value="true"/>
                    <UserString key="ToolTipType" value="Layout"/>
                    <UserString key="ToolTipLayout" value="HealthToolTip"/>
                    <UserString key="ImageTexture_HealthImage" value="icons\k\health.dds"/>
                    <Widget type="TextBox" skin="NormalTextController" position="0 0 70 18" name="Health_str" align="Left Top HStretch">
                        <Property key="NeedMouse" value="false"/>
                        <Property key="Caption" value="#{sHealth}"/>
                    </Widget>
                    <Widget type="ProgressBar" skin="MW_Progress_Red" position="74 0 130 18" name="HBar" align="Right Top">
                        <Property key="NeedMouse" value="false"/>
                        <Widget type="TextBox" skin="ProgressTextController" position="0 0 130 16" name="HBarT" align="Right VCenter">
                            <Property key="NeedMouse" value="false"/>
                        </Widget>
                    </Widget>
                </Widget>

                <!-- Magicka -->
                <Widget type="Widget" skin="" position="4 22 204 18" name="Magicka" align="Left Top HStretch">
                    <Property key="NeedMouse" value="true"/>
                    <UserString key="ToolTipType" value="Layout"/>
                    <UserString key="ToolTipLayout" value="HealthToolTip"/>
                    <UserString key="ImageTexture_HealthImage" value="icons\k\magicka.dds"/>

                    <Widget type="TextBox" skin="NormalTextController" position="0 0 70 18" name="Magicka_str" align="Left Top HStretch">
                        <Property key="Caption" value="#{sMagic}"/>
                        <Property key="NeedMouse" value="false"/>
                    </Widget>

                    <Widget type="ProgressBar" skin="MW_Progress_Blue" position="74 0 130 18" name="MBar" align="Right Top">
                        <Property key="NeedMouse" value="false"/>
                        <Widget type="TextBox" skin="ProgressTextController" position="0 0 130 16" name="MBarT" align="Right VCenter">
                            <Property key="NeedMouse" value="false"/>
                        </Widget>
                    </Widget>
                </Widget>

                <!-- Fatigue -->
                <Widget type="Widget" skin="" position="4 40 204 18" name="Fatigue" align="Left Top HStretch">
                    <Property key="NeedMouse" value="true"/>
                    <UserString key="ToolTipType" value="Layout"/>
                    <UserString key="ToolTipLayout" value="HealthToolTip"/>
                    <UserString key="ImageTexture_HealthImage" value="icons\k\fatigue.dds"/>

                    <Widget type="TextBox" skin="NormalTextController" position="0 0 70 18" name="Fatigue_str" align="Left Top HStretch">
                        <Property key="Caption" value="#{sFatigue}"/>
                        <Property key="NeedMouse" value="false"/>
                    </Widget>

                    <Widget type="ProgressBar" skin="MW_Progress_Green" position="74 0 130 18" name="FBar" align="Right Top">
                        <Property key="NeedMouse" value="false"/>
                        <Widget type="TextBox" skin="ProgressTextController" position="0 0 130 16" name="FBarT" align="Right VCenter">
                            <Property key="NeedMouse" value="false"/>
                        </Widget>
                    </Widget>
                </Widget>
            </Widget>

            <!-- Player level, race and class -->
            <Widget type="Widget" skin="MW_Box" position="8 78 212 80" align="Top HStretch">
                <Widget type="HBox" position="4 4 204 18" align="Top HStretch">
                    <Widget type="AutoSizedTextBox" skin="NormalTextController" position="0 0 200 18" name="Name_str" align="Left Top">
                        <Property key="Caption" value="#{sName}"/>
                        <UserString key="ToolTipType" value="Layout"/>
                        <UserString key="ToolTipLayout" value="RaceToolTip"/>
                        <UserString key="ForceCollapsedTooltip" value="true"/>
                    </Widget>
                    <Widget type="TextBox" skin="SandTextRightController" position="200 0 40 18" name="NameText" align="Right Top">
                        <Property key="TextAlign" value="Right Top"/>
                        <UserString key="ToolTipType" value="Layout"/>
                        <UserString key="ToolTipLayout" value="RaceToolTip"/>
                        <UserString key="ForceCollapsedTooltip" value="true"/>
                        <UserString key="HStretch" value="true"/>
                    </Widget>
                </Widget>
                <Widget type="HBox" position="4 22 204 18" align="Top HStretch">
                    <Widget type="AutoSizedTextBox" skin="NormalTextController" position="0 0 200 18" name="Level_str" align="Left Top">
                        <Property key="Caption" value="#{sLevel}"/>
                        <UserString key="ToolTipType" value="Layout"/>
                        <UserString key="ToolTipLayout" value="LevelToolTip"/>
                    </Widget>
                    <Widget type="TextBox" skin="SandTextRightController" position="200 0 40 18" name="LevelText" align="Right Top">
                        <Property key="TextAlign" value="Right Top"/>
                        <UserString key="ToolTipType" value="Layout"/>
                        <UserString key="ToolTipLayout" value="LevelToolTip"/>
                        <UserString key="HStretch" value="true"/>
                    </Widget>

                </Widget>
                <Widget type="HBox" position="4 42 204 18" align="Top HStretch">
                    <Widget type="AutoSizedTextBox" skin="NormalTextController" position="0 0 95 18" name="Race_str" align="Left Top">
                        <Property key="Caption" value="#{sRace}"/>
                        <UserString key="ToolTipType" value="Layout"/>
                        <UserString key="ToolTipLayout" value="RaceToolTip"/>
                    </Widget>
                    <Widget type="TextBox" skin="SandTextRightController" position="104 0 200 18" name="RaceText" align="Left Top">
                        <Property key="TextAlign" value="Right Top"/>
                        <UserString key="ToolTipType" value="Layout"/>
                        <UserString key="ToolTipLayout" value="RaceToolTip"/>
                        <UserString key="HStretch" value="true"/>
                    </Widget>
                </Widget>
                <Widget type="HBox" position="4 60 204 18" align="Top HStretch">
                    <Widget type="AutoSizedTextBox" skin="NormalTextController" position="0 0 95 18" name="Class_str" align="Left Top">
                        <Property key="Caption" value="#{sClass}"/>
                        <UserString key="ToolTipType" value="Layout"/>
                        <UserString key="ToolTipLayout" value="ClassToolTip"/>
                    </Widget>
                    <Widget type="TextBox" skin="SandTextRightController" position="104 0 200 18" name="ClassText" align="Left Top">
                        <Property key="TextAlign" value="Right Top"/>
                        <UserString key="ToolTipType" value="Layout"/>
                        <UserString key="ToolTipLayout" value="ClassToolTip"/>
                        <UserString key="HStretch" value="true"/>
                    </Widget>
                </Widget>
            </Widget>

            <Widget type="Widget" skin="MW_Box" position="8 166 212 168" align="Left Top Stretch">
                <!-- TODO: this should be a scroll view -->
                <Widget type="Widget" skin="" position="4 4 204 160" align="Left Top Stretch" name="AttributeView" />
            </Widget>

        </Widget>

        <Widget type="Widget" skin="" name="RightPane" position="220 0 280 342" align="Stretch">

            <!-- Player skills, factions, birthsign and reputation -->
            <Widget type="Widget" skin="MW_Box" position="8 8 263 326" align="Left Stretch" name="Skills">
                <Widget type="ScrollView" skin="MW_ScrollView" position="4 2 261 318" align="Left Top Stretch" name="SkillView">
                    <Property key="CanvasAlign" value="Left Top"/>
                </Widget>
            </Widget>

        </Widget>

    </Widget>
</MyGUI>
